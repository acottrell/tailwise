STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
NEXT_PUBLIC_STRAVA_CLIENT_ID=
NEXT_PUBLIC_MAPBOX_TOKEN=

# Vercel Postgres (Neon)
POSTGRES_URL=

# Server-side Strava token for fetching route polylines
STRAVA_API_TOKEN=

# Admin secret for seed/approve/delete endpoints
ADMIN_SECRET=

# LBRCC club admin (shared with club ride leaders)
LBRCC_ADMIN_SECRET=

# Resend (email notifications for route submissions)
RESEND_API_KEY=
ADMIN_EMAIL=

# Google Places API — NOT needed for geocoding (that uses OpenStreetMap's
# Nominatim, no key). Only required if/when the cafe opening-hours feature
# is built.
GOOGLE_PLACES_API_KEY=

# Upstash Redis — durable rate limiting (create a store at upstash.com).
# If unset, rate limiting is skipped (fine for local dev, required in prod).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
